<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="10dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="2dp"
    app:cardBackgroundColor="#FFFFFF">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="16dp">

        <!-- TEXTOS -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvFecha"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="25 de Octubre"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="#1A1A1A"
                android:layout_marginBottom="4dp"/>

            <LinearLayout
                android:id="@+id/layoutHoras"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <ImageView
                    android:layout_width="14dp"
                    android:layout_height="14dp"
                    android:src="@android:drawable/ic_menu_send"
                    app:tint="#2E7D32"
                    android:layout_marginEnd="4dp"/>

                <TextView
                    android:id="@+id/tvEntrada"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="08:55 AM"
                    android:textSize="12sp"
                    android:textColor="#1A1A1A"
                    android:layout_marginEnd="12dp"/>

                <ImageView
                    android:layout_width="14dp"
                    android:layout_height="14dp"
                    android:src="@android:drawable/ic_menu_send"
                    app:tint="#857661"
                    android:layout_marginEnd="4dp"/>

                <TextView
                    android:id="@+id/tvSalida"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="06:05 PM"
                    android:textSize="12sp"
                    android:textColor="#1A1A1A"/>

            </LinearLayout>

            <!-- Texto alternativo para ausentes -->
            <TextView
                android:id="@+id/tvSinRegistro"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Sin registros de entrada o salida"
                android:textSize="12sp"
                android:textColor="#857661"
                android:textStyle="italic"
                android:visibility="gone"/>

        </LinearLayout>

        <!-- BADGE ESTADO -->
        <TextView
            android:id="@+id/tvEstado"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="PUNTUAL"
            android:textSize="11sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:background="@drawable/bg_badge_estado"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:paddingTop="6dp"
            android:paddingBottom="6dp"/>

    </LinearLayout>
</androidx.cardview.widget.CardView>