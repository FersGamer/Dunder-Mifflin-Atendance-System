<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#EFE7DA"
    android:paddingTop="30dp">

    <!-- Encabezado Fijo -->
    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@android:color/white"
        app:layout_constraintTop_toTopOf="parent">

        <!-- Foto de Perfil (Inicio) -->
        <com.google.android.material.imageview.ShapeableImageView
            android:id="@+id/ivProfileToolbar"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_gravity="start"
            android:src="@drawable/ejemplo"
            android:scaleType="centerCrop"
            app:shapeAppearanceOverlay="@style/ShapeAppearance.Circle" />

        <!-- Título -->
        <TextView
            android:id="@+id/tvToolbarTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="start"
            android:layout_marginStart="12dp"
            android:text="Mi Codigo QR"
            android:textColor="#002855"
            android:textSize="20sp"
            android:textStyle="bold" />

        <!-- Botón de Notificación (Fin) -->
        <ImageButton
            android:id="@+id/btnNotificaciones"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_gravity="end"
            android:layout_marginEnd="8dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:padding="12dp"
            android:scaleType="fitCenter"
            android:src="@drawable/ic_notificacion"
            app:tint="#5F6368"
            android:contentDescription="Notificaciones" />

    </com.google.android.material.appbar.MaterialToolbar>

    <!-- Contenido Scrollable Centrado -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintTop_toBottomOf="@id/toolbar"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- TABS ENTRADA / SALIDA -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="350dp"
                android:layout_height="56dp"
                app:cardCornerRadius="10dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="#F5F5F5"
                app:strokeWidth="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="horizontal"
                    android:padding="4dp">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnEntrada"
                        style="@style/Widget.MaterialComponents.Button.UnelevatedButton"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:text="ENTRADA"
                        android:textColor="#FFFFFF"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        app:icon="@drawable/ic_entrada"
                        app:iconGravity="textStart"
                        app:iconTint="#FFFFFF"
                        app:iconPadding="10dp"
                        app:iconSize="20dp"
                        android:backgroundTint="#2E7D32"
                        app:cornerRadius="28dp"/>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnSalida"
                        style="@style/Widget.MaterialComponents.Button.UnelevatedButton"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:text="SALIDA"
                        android:textColor="#757575"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        app:icon="@drawable/ic_salida"
                        app:iconGravity="textStart"
                        app:iconTint="#757575"
                        app:iconPadding="10dp"
                        app:iconSize="20dp"
                        android:backgroundTint="@android:color/transparent"
                        app:cornerRadius="28dp"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- TARJETA PRINCIPAL -->
            <androidx.cardview.widget.CardView
                android:layout_width="350dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="20dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="#FFFFFF">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:padding="24dp">

                    <!-- NOMBRE -->
                    <TextView
                        android:id="@+id/tvNombreQr"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Nombre Apellido"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:textColor="#1A1A1A"
                        android:layout_marginBottom="4dp"/>

                    <!-- SUBTÍTULO/PLAN -->
                    <TextView
                        android:id="@+id/tvPlanQr"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Pase de Asistencia"
                        android:textSize="13sp"
                        android:textColor="#857661"
                        android:layout_marginBottom="20dp"/>

                    <!-- QR -->
                    <androidx.cardview.widget.CardView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="20dp"
                        app:cardCornerRadius="16dp"
                        app:cardElevation="6dp"
                        app:cardBackgroundColor="#5F9EA0">

                        <ImageView
                            android:id="@+id/ivQrCode"
                            android:layout_width="180dp"
                            android:layout_height="180dp"
                            android:padding="16dp"
                            android:scaleType="fitCenter"/>

                    </androidx.cardview.widget.CardView>

                    <!-- CONTADOR CIRCULAR -->
                    <ProgressBar
                        android:id="@+id/progressContador"
                        style="?android:attr/progressBarStyleHorizontal"
                        android:layout_width="70dp"
                        android:layout_height="70dp"
                        android:indeterminate="false"
                        android:max="60"
                        android:progress="45"
                        android:progressDrawable="@drawable/bg_progreso_circular"
                        android:layout_marginBottom="4dp"/>

                    <TextView
                        android:id="@+id/tvContador"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="45s"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="#2E7D32"
                        android:layout_marginTop="-52dp"
                        android:layout_marginBottom="48dp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Válido por:"
                        android:textSize="13sp"
                        android:textColor="#857661"/>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- SECCIÓN ÚLTIMOS REGISTROS -->
            <LinearLayout
                android:layout_width="350dp"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingBottom="16dp">

                <!-- HEADER -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="12dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Último registro"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="#1A1A1A"/>

                    <ImageView
                        android:layout_width="22dp"
                        android:layout_height="22dp"
                        android:src="@android:drawable/ic_menu_recent_history"
                        app:tint="#857661"/>
                </LinearLayout>

                <!-- LISTA DINÁMICA -->
                <LinearLayout
                    android:id="@+id/layoutRegistros"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="#FFFFFF"
                    android:padding="8dp"/>

            </LinearLayout>
        </LinearLayout>
    </ScrollView>
</androidx.constraintlayout.widget.ConstraintLayout>
