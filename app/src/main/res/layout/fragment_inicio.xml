<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#EFE7DA"
    android:paddingTop="30dp">

    <!-- Encabezado Fijo -->
    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@android:color/white"
        app:layout_constraintTop_toTopOf="parent">

        <!-- Foto de Perfil (Inicio) -->
        <com.google.android.material.imageview.ShapeableImageView
            android:id="@+id/ivProfileToolbar"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_gravity="start"
            android:src="@drawable/ejemplo"
            android:scaleType="centerCrop"
            app:shapeAppearanceOverlay="@style/ShapeAppearance.Circle" />

        <!-- Título -->
        <TextView
            android:id="@+id/tvToolbarTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="start"
            android:layout_marginStart="12dp"
            android:text="Dunder Mifflin"
            android:textColor="#002855"
            android:textSize="20sp"
            android:textStyle="bold" />

        <!-- Botón de Notificación (Fin) -->
        <ImageButton
            android:id="@+id/btnNotificaciones"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_gravity="end"
            android:layout_marginEnd="8dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:padding="12dp"
            android:scaleType="fitCenter"
            android:src="@drawable/ic_notificacion"
            app:tint="#5F6368"
            android:contentDescription="Notificaciones" />

    </com.google.android.material.appbar.MaterialToolbar>

    <!-- Contenido Scrollable -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/toolbar"
        app:layout_constraintBottom_toBottomOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- TARJETA PERFIL -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="20dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="#FFFFFF">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:padding="24dp">

                    <!-- FOTO CON INDICADOR ONLINE -->
                    <FrameLayout
                        android:layout_width="100dp"
                        android:layout_height="100dp"
                        android:layout_marginBottom="12dp">

                        <com.google.android.material.imageview.ShapeableImageView
                            android:id="@+id/ivFotoPerfil"
                            android:layout_width="100dp"
                            android:layout_height="100dp"
                            android:src="@drawable/ejemplo"
                            android:background="@drawable/bg_foto"
                            android:padding="4dp"
                            android:scaleType="centerCrop"
                            app:shapeAppearanceOverlay="@style/ShapeAppearance.Circle"/>
                    </FrameLayout>

                    <!-- NOMBRE -->
                    <TextView
                        android:id="@+id/tvNombreUsuario"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Nombre Apellido"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:textColor="#3B4C39"
                        android:layout_marginBottom="10dp"/>

                    <!-- BADGES -->
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="20dp">

                        <TextView
                            android:id="@+id/tvDepartamento"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Departamento"
                            android:textSize="12sp"
                            android:textColor="#857661"
                            android:background="@drawable/bg_badge_gris"
                            android:paddingStart="12dp"
                            android:paddingEnd="12dp"
                            android:paddingTop="4dp"
                            android:paddingBottom="4dp"
                            android:layout_marginEnd="8dp"/>

                        <TextView
                            android:id="@+id/tvTurno"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Turno: 9:00- 15:00"
                            android:textSize="12sp"
                            android:textColor="#EFE7DA"
                            android:background="@drawable/bg_badge_azul"
                            android:paddingStart="12dp"
                            android:paddingEnd="12dp"
                            android:paddingTop="4dp"
                            android:paddingBottom="4dp"/>
                    </LinearLayout>

                    <!-- BOTÓN REGISTRAR -->
                    <Button
                        android:id="@+id/btnRegistrarUso"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:text="Registrar Uso"
                        android:textColor="#EFE7DA"
                        android:textSize="15sp"
                        android:backgroundTint="@color/primario_azul"
                        android:stateListAnimator="@null"
                        app:cornerRadius="50dp"/>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- GRID DE STATS 2x2 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <!-- FILA 1 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="12dp">

                    <!-- Asiatencias -->
                    <androidx.cardview.widget.CardView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginEnd="6dp"
                        app:cardCornerRadius="16dp"
                        app:cardElevation="3dp"
                        app:cardBackgroundColor="#FFFFFF">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="16dp">

                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal"
                                android:gravity="center_vertical"
                                android:layout_marginBottom="8dp">

                                <ImageView
                                    android:layout_width="24dp"
                                    android:layout_height="24dp"
                                    android:src="@drawable/ic_palomita"
                                    app:tint="#3B4C39"
                                    android:layout_marginEnd="6dp"/>

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Asistencias"
                                    android:textSize="13sp"
                                    android:textColor="#857661"/>
                            </LinearLayout>

                            <TextView
                                android:id="@+id/tvAsiatencia"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="00"
                                android:textSize="28sp"
                                android:textStyle="bold"
                                android:textColor="#3B4C39"
                                android:layout_marginBottom="4dp"/>

                            <TextView
                                android:id="@+id/tvAsistenciasMes"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="+0 este mes"
                                android:textSize="12sp"
                                android:textColor="#3B4C39"/>
                        </LinearLayout>
                    </androidx.cardview.widget.CardView>

                    <!-- Faltas -->
                    <androidx.cardview.widget.CardView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="6dp"
                        app:cardCornerRadius="16dp"
                        app:cardElevation="3dp"
                        app:cardBackgroundColor="#FFFFFF">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="16dp">

                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal"
                                android:gravity="center_vertical"
                                android:layout_marginBottom="8dp">

                                <ImageView
                                    android:layout_width="24dp"
                                    android:layout_height="24dp"
                                    android:src="@drawable/ic_tache"
                                    app:tint="#753D30"
                                    android:layout_marginEnd="6dp"/>

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Faltas"
                                    android:textSize="13sp"
                                    android:textColor="#857661"/>
                            </LinearLayout>

                            <TextView
                                android:id="@+id/tvFaltas"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="00"
                                android:textSize="28sp"
                                android:textStyle="bold"
                                android:textColor="#3B4C39"
                                android:layout_marginBottom="4dp"/>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Sin faltas"
                                android:textSize="12sp"
                                android:textColor="#753D30"/>
                        </LinearLayout>
                    </androidx.cardview.widget.CardView>

                </LinearLayout>

                <!-- FILA 2 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <!-- TIEMPO -->
                    <androidx.cardview.widget.CardView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginEnd="6dp"
                        app:cardCornerRadius="16dp"
                        app:cardElevation="3dp"
                        app:cardBackgroundColor="#FFFFFF">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="16dp">

                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal"
                                android:gravity="center_vertical"
                                android:layout_marginBottom="8dp">

                                <ImageView
                                    android:layout_width="24dp"
                                    android:layout_height="24dp"
                                    android:src="@drawable/ic_retardos"
                                    app:tint="#A67857"
                                    android:layout_marginEnd="6dp"/>

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Retardos"
                                    android:textSize="13sp"
                                    android:textColor="#857661"/>
                            </LinearLayout>

                            <TextView
                                android:id="@+id/tvTiempo"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="00"
                                android:textSize="28sp"
                                android:textStyle="bold"
                                android:textColor="#3B4C39"
                                android:layout_marginBottom="4dp"/>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Sin Retardos"
                                android:textSize="12sp"
                                android:textColor="#A67857"/>
                        </LinearLayout>
                    </androidx.cardview.widget.CardView>

                    <!-- PLAN ACTIVO -->
                    <androidx.cardview.widget.CardView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="6dp"
                        app:cardCornerRadius="16dp"
                        app:cardElevation="3dp"
                        app:cardBackgroundColor="#FFFFFF">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="16dp">

                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal"
                                android:gravity="center_vertical"
                                android:layout_marginBottom="8dp">

                                <ImageView
                                    android:layout_width="24dp"
                                    android:layout_height="24dp"
                                    android:src="@drawable/ic_vacaciones"
                                    app:tint="#857661"
                                    android:layout_marginEnd="6dp"/>

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Vacaciones "
                                    android:textSize="13sp"
                                    android:textColor="#857661"/>
                            </LinearLayout>

                            <TextView
                                android:id="@+id/tvDiasRestantes"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="00"
                                android:textSize="28sp"
                                android:textStyle="bold"
                                android:textColor="#3B4C39"
                                android:layout_marginBottom="4dp"/>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Días restantes"
                                android:textSize="12sp"
                                android:textColor="#857661"/>
                        </LinearLayout>
                    </androidx.cardview.widget.CardView>

                </LinearLayout>
            </LinearLayout>
        </LinearLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>