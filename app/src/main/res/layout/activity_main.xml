<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F3ED">

    <!-- Cuerpo: El fragmentContainer ocupa casi toda la pantalla -->
    <FrameLayout
        android:id="@+id/fragmentContainer"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/customBottomNav"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Bottom Menu Personalizado -->
    <LinearLayout
        android:id="@+id/customBottomNav"
        android:layout_width="match_parent"
        android:layout_height="80dp"
        android:background="#F8F9FB"
        android:orientation="horizontal"
        android:gravity="center"
        android:paddingHorizontal="16dp"
        app:layout_constraintBottom_toBottomOf="parent">

        <!-- Inicio -->
        <LinearLayout
            android:id="@+id/nav_inicio"
            android:layout_width="0dp"
            android:layout_height="60dp"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true">
            <ImageView
                android:id="@+id/iv_inicio"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_inicio"
                app:tint="#757575"/>
            <TextView
                android:id="@+id/tv_inicio"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Inicio"
                android:textSize="12sp"
                android:textColor="#757575"/>
        </LinearLayout>

        <!-- QR -->
        <LinearLayout
            android:id="@+id/nav_qr"
            android:layout_width="0dp"
            android:layout_height="60dp"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true">
            <ImageView
                android:id="@+id/iv_qr"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_qr"
                app:tint="#757575"/>
            <TextView
                android:id="@+id/tv_qr"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="QR"
                android:textSize="12sp"
                android:textColor="#757575"/>
        </LinearLayout>

        <!-- Asistencia -->
        <LinearLayout
            android:id="@+id/nav_asistencia"
            android:layout_width="0dp"
            android:layout_height="60dp"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true">
            <ImageView
                android:id="@+id/iv_asistencia"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_asistencia"
                app:tint="#757575"/>
            <TextView
                android:id="@+id/tv_asistencia"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Asistencia"
                android:textSize="12sp"
                android:textColor="#757575"/>
        </LinearLayout>

        <!-- Solicitudes -->
        <LinearLayout
            android:id="@+id/nav_solicitudes"
            android:layout_width="0dp"
            android:layout_height="60dp"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true">
            <ImageView
                android:id="@+id/iv_solicitudes"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_solicitud"
                app:tint="#757575"/>
            <TextView
                android:id="@+id/tv_solicitudes"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Solicitudes"
                android:textSize="12sp"
                android:textColor="#757575"/>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/nav_agenda"
            android:layout_width="0dp"
            android:layout_height="60dp"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true">
            <ImageView
                android:id="@+id/iv_agenda"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_agenda"
                app:tint="#757575"/>
            <TextView
                android:id="@+id/tv_agenda"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Agenda"
                android:textSize="12sp"
                android:textColor="#757575"/>
        </LinearLayout>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>