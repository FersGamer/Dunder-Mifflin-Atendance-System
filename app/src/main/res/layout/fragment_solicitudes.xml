<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#EFE7DA">

    <!-- Encabezado Fijo -->
    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@android:color/white"
        app:layout_constraintTop_toTopOf="parent">

        <!-- Foto de Perfil -->
        <com.google.android.material.imageview.ShapeableImageView
            android:id="@+id/ivProfileToolbar"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_gravity="start"
            android:scaleType="centerCrop"
            android:src="@drawable/ejemplo"
            app:shapeAppearanceOverlay="@style/ShapeAppearance.Circle" />

        <!-- Título -->
        <TextView
            android:id="@+id/tvToolbarTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="start"
            android:layout_marginStart="12dp"
            android:text="@string/dunder_mifflin"
            android:textColor="#002855"
            android:textSize="20sp"
            android:textStyle="bold" />

        <!-- Botón de Notificación -->
        <ImageButton
            android:id="@+id/btnNotificaciones"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_gravity="end"
            android:layout_marginEnd="8dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Notificaciones"
            android:padding="12dp"
            android:scaleType="fitCenter"
            android:src="@drawable/ic_notificacion"
            app:tint="#5F6368" />

    </com.google.android.material.appbar.MaterialToolbar>

    <!-- Contenido Scrollable -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/toolbar">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#F5F5F5"
            android:orientation="vertical">

            <!-- TABS -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:background="#FFFFFF"
                android:orientation="horizontal"
                android:padding="6dp"
                android:weightSum="2">

                <Button
                    android:id="@+id/btnVacaciones"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:backgroundTint="#FFFFFF"
                    android:stateListAnimator="@null"
                    android:text="Vacaciones"
                    android:textColor="#857661"
                    android:textSize="13sp"
                    app:cornerRadius="10dp" />

                <Button
                    android:id="@+id/btnPermiso"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:backgroundTint="#1A2E4A"
                    android:stateListAnimator="@null"
                    android:text="Permiso"
                    android:textColor="#FFFFFF"
                    android:textSize="13sp"
                    app:cornerRadius="10dp" />

            </LinearLayout>

            <!-- CONTENEDOR SUB-FRAGMENTO -->
            <FrameLayout
                android:id="@+id/subFragmentContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minHeight="200dp" />

            <!-- HISTORIAL RECIENTE -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="#FFFFFF"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp"
                    android:text="Historial Reciente"
                    android:textColor="#1A1A1A"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <LinearLayout
                    android:id="@+id/layoutHistorial"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical" />

            </LinearLayout>

        </LinearLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
