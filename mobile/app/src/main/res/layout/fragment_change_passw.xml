<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">
        <!-- PASO INDICADOR -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginBottom="24dp">

            <com.google.android.material.imageview.ShapeableImageView
                android:layout_width="60dp"
                android:layout_height="10dp"
                app:shapeAppearanceOverlay="@style/ShapeAppearance.barra"
                android:background="@color/primario_azul"
                android:layout_marginEnd="4dp"/>
            <com.google.android.material.imageview.ShapeableImageView
                android:layout_width="60dp"
                android:layout_height="4dp"
                android:layout_gravity="center_vertical"
                app:shapeAppearanceOverlay="@style/ShapeAppearance.barra"
                android:background="@color/neutral_gris"/>
        </LinearLayout>

        <!-- TÍTULO -->
        <TextView
            android:layout_width="208dp"
            android:layout_height="60dp"
            android:layout_marginBottom="8dp"
            android:text="Paso 1: Actualiza tu contraseña"
            android:textColor="@color/primario_azul"
            android:textSize="22sp"
            android:textStyle="bold" />

        <!-- SUBTÍTULO -->
        <TextView
            android:layout_width="219dp"
            android:layout_height="wrap_content"
            android:layout_marginBottom="32dp"
            android:lineSpacingExtra="4dp"
            android:text="Por seguridad, debes cambiar la contraseña temporal asignada."
            android:textColor="@color/secundario_gris"
            android:textSize="14sp" />

        <!-- CAMPO: CONTRASEÑA ACTUAL -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Contraseña actual"
            android:textSize="13sp"
            android:textColor="#3B4C39"
            android:textStyle="bold"
            android:layout_marginBottom="6dp"/>

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/tilPasswordActual"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="20dp"
            app:passwordToggleEnabled="true"
            app:boxBackgroundColor="#FFFFFF"
            app:boxStrokeColor="#3B4C39"
            app:boxCornerRadiusTopStart="12dp"
            app:boxCornerRadiusTopEnd="12dp"
            app:boxCornerRadiusBottomStart="12dp"
            app:boxCornerRadiusBottomEnd="12dp">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etPasswordActual"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="••••••••"
                android:inputType="textPassword"
                android:textColor="#3B4C39"
                android:textColorHint="#857661"/>
        </com.google.android.material.textfield.TextInputLayout>

        <!-- CAMPO: NUEVA CONTRASEÑA -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Nueva contraseña"
            android:textSize="13sp"
            android:textColor="#3B4C39"
            android:textStyle="bold"
            android:layout_marginBottom="6dp"/>

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/tilPasswordNueva"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="20dp"
            app:passwordToggleEnabled="true"
            app:boxBackgroundColor="#FFFFFF"
            app:boxStrokeColor="#3B4C39"
            app:boxCornerRadiusTopStart="12dp"
            app:boxCornerRadiusTopEnd="12dp"
            app:boxCornerRadiusBottomStart="12dp"
            app:boxCornerRadiusBottomEnd="12dp">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etPasswordNueva"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Mínimo 8 caracteres"
                android:inputType="textPassword"
                android:textColor="#3B4C39"
                android:textColorHint="#857661"/>
        </com.google.android.material.textfield.TextInputLayout>

        <!-- CAMPO: CONFIRMAR CONTRASEÑA -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Confirmar nueva contraseña"
            android:textSize="13sp"
            android:textColor="#3B4C39"
            android:textStyle="bold"
            android:layout_marginBottom="6dp"/>

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/tilPasswordConfirmar"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="20dp"
            app:passwordToggleEnabled="true"
            app:boxBackgroundColor="#FFFFFF"
            app:boxStrokeColor="#3B4C39"
            app:boxCornerRadiusTopStart="12dp"
            app:boxCornerRadiusTopEnd="12dp"
            app:boxCornerRadiusBottomStart="12dp"
            app:boxCornerRadiusBottomEnd="12dp">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etPasswordConfirmar"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Repite tu contraseña"
                android:inputType="textPassword"
                android:textColor="#3B4C39"
                android:textColorHint="#857661"/>
        </com.google.android.material.textfield.TextInputLayout>

        <!-- NOTA DE SEGURIDAD -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="@drawable/bg_nota_info"
            android:padding="14dp"
            android:gravity="center_vertical"
            android:layout_marginBottom="32dp">

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@android:drawable/ic_dialog_info"
                app:tint="#857661"
                android:layout_marginEnd="10dp"/>

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Tu contraseña debe incluir al menos una mayúscula, un número y un símbolo."
                android:textSize="13sp"
                android:textColor="#857661"
                android:lineSpacingExtra="3dp"/>
        </LinearLayout>

        <!-- BOTÓN SIGUIENTE -->
        <Button
            android:id="@+id/btnSiguiente"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="Siguiente →"
            android:textColor="@color/white"
            android:textSize="16sp"
            android:backgroundTint="@color/primario_azul"
            android:stateListAnimator="@null"
            android:layout_marginBottom="16dp"
            app:cornerRadius="50dp"/>

        <!-- LINK AYUDA -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:text="¿Necesitas ayuda técnica? Contacta a IT"
            android:textSize="13sp"
            android:textColor="@color/primario_azul"
            android:textStyle="italic"/>

    </LinearLayout>
</ScrollView>