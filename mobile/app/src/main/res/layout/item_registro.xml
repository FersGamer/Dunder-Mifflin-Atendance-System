<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:padding="12dp"
    android:background="?attr/selectableItemBackground">

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tvTipoRegistro"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Uso de Bici"
            android:textSize="15sp"
            android:textStyle="bold"
            android:textColor="#3B4C39" />

        <TextView
            android:id="@+id/tvFechaRegistro"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="09:02 AM • 24 Oct 2023"
            android:textSize="12sp"
            android:textColor="#857661"
            android:layout_marginTop="2dp" />
    </LinearLayout>

    <TextView
        android:id="@+id/tvEstado"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="COMPLETADO"
        android:textSize="11sp"
        android:textStyle="bold"
        android:textColor="#FFFFFF"
        android:paddingHorizontal="10dp"
        android:paddingVertical="4dp"
        android:background="@drawable/bg_badge_gris" />

</LinearLayout>